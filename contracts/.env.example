# Midnight Testnet Configuration
# Copy this to contracts/.env and fill in your values

# Get these from https://docs.midnight.network/testnet
MIDNIGHT_INDEXER_URI=https://indexer.testnet.midnight.network/api/v1/graphql
MIDNIGHT_NODE_URI=https://rpc.testnet.midnight.network
MIDNIGHT_ZK_CONFIG_URI=https://zk.testnet.midnight.network

# Your Midnight wallet seed (get from midnight-wallet-cli)
MIDNIGHT_WALLET_SEED=your_wallet_seed_here
